<Window x:Class="SoftwareAccounting.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="ИНФОРМАЦИОННАЯ СИСТЕМА УЧЕТА ПРОГРАММНОГО ОБЕСПЕЧЕНИЯ" 
        Height="750" Width="1300" WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="5" Margin="0,0,0,10" Padding="10">
            <TextBlock Text="ИНФОРМАЦИОННАЯ СИСТЕМА УЧЕТА ПРОГРАММНОГО ОБЕСПЕЧЕНИЯ" 
                       FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" 
                       Foreground="White"/>
        </Border>

        <!-- Панель ввода -->
        <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="2" CornerRadius="5" 
                Padding="15" Margin="0,0,0,10" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="Название ПО:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Name="txtName" Width="250" Height="30" Margin="5" 
                         VerticalContentAlignment="Center" HorizontalAlignment="Left"/>

                <Label Grid.Row="0" Grid.Column="2" Content="Версия:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="3" Name="txtVersion" Width="200" Height="30" Margin="5" 
                         VerticalContentAlignment="Center" HorizontalAlignment="Left"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Тип лицензии:" FontWeight="Bold" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1" Name="cmbLicenseType" Width="250" Height="30" Margin="5" 
                          HorizontalAlignment="Left">
                    <ComboBoxItem Content="Free"/>
                    <ComboBoxItem Content="Trial"/>
                    <ComboBoxItem Content="Subscription"/>
                    <ComboBoxItem Content="Perpetual"/>
                    <ComboBoxItem Content="Open Source"/>
                    <ComboBoxItem Content="Enterprise"/>
                </ComboBox>

                <Label Grid.Row="1" Grid.Column="2" Content="Производитель:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="3" Name="txtManufacturer" Width="200" Height="30" Margin="5" 
                         VerticalContentAlignment="Center" HorizontalAlignment="Left"/>

                <Label Grid.Row="2" Grid.Column="0" Content="Дата покупки:" FontWeight="Bold" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="2" Grid.Column="1" Name="dpPurchaseDate" Width="250" Height="30" Margin="5" 
                            HorizontalAlignment="Left" SelectedDate="{x:Static sys:DateTime.Now}"/>

                <Label Grid.Row="2" Grid.Column="2" Content="Стоимость (₽):" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="3" Name="txtCost" Width="200" Height="30" Margin="5" 
                         VerticalContentAlignment="Center" HorizontalAlignment="Left" Text="0"/>

                <Label Grid.Row="3" Grid.Column="0" Content="Ответственный:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" Name="txtResponsible" Width="250" Height="30" Margin="5" 
                         VerticalContentAlignment="Center" HorizontalAlignment="Left"/>

                <Label Grid.Row="3" Grid.Column="2" Content="Кол-во пользователей:" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="3" Name="txtUserCount" Width="200" Height="30" Margin="5" 
                         VerticalContentAlignment="Center" HorizontalAlignment="Left" Text="1"/>

                <Label Grid.Row="4" Grid.Column="0" Content="Окончание лицензии:" FontWeight="Bold" VerticalAlignment="Center"/>
                <DatePicker Grid.Row="4" Grid.Column="1" Name="dpExpirationDate" Width="250" Height="30" Margin="5" 
                            HorizontalAlignment="Left" SelectedDate="{x:Static sys:DateTime.Now}"/>

                <Label Grid.Row="4" Grid.Column="2" Content="Примечания:" FontWeight="Bold" VerticalAlignment="Top" Margin="5,10,5,0"/>
                <TextBox Grid.Row="4" Grid.Column="3" Name="txtNotes" Width="300" Height="60" Margin="5" 
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                         HorizontalAlignment="Left"/>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <WrapPanel Grid.Row="2" Margin="0,0,0,10" HorizontalAlignment="Center">
            <Button Name="btnAdd" Content="+ ДОБАВИТЬ" Background="#27AE60" Foreground="White" 
                    Width="130" Height="35" Margin="5" FontWeight="Bold" Cursor="Hand" Click="BtnAdd_Click"/>
            <Button Name="btnUpdate" Content="ОБНОВИТЬ" Background="#3498DB" Foreground="White" 
                    Width="130" Height="35" Margin="5" FontWeight="Bold" Cursor="Hand" Click="BtnUpdate_Click"/>
            <Button Name="btnDelete" Content="УДАЛИТЬ" Background="#E74C3C" Foreground="White" 
                    Width="130" Height="35" Margin="5" FontWeight="Bold" Cursor="Hand" Click="BtnDelete_Click"/>
            <Button Name="btnClear" Content="ОЧИСТИТЬ" Background="#95A5A6" Foreground="White" 
                    Width="130" Height="35" Margin="5" FontWeight="Bold" Cursor="Hand" Click="BtnClear_Click"/>
            <Button Name="btnRefresh" Content="ОБНОВИТЬ СПИСОК" Background="#F39C12" Foreground="White" 
                    Width="150" Height="35" Margin="5" FontWeight="Bold" Cursor="Hand" Click="BtnRefresh_Click"/>
        </WrapPanel>

        <!-- Таблица данных -->
        <DataGrid Grid.Row="3" Name="dgSoftware" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionChanged="DgSoftware_SelectionChanged"
                  AlternatingRowBackground="#F9F9F9" RowHeight="35" Margin="5"
                  FontSize="12" BorderBrush="#BDC3C7" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="140"/>
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="80"/>
                <DataGridTextColumn Header="LicenseType" Binding="{Binding LicenseType}" Width="100"/>
                <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="140"/>
                <DataGridTextColumn Header="PurchaseDate" Binding="{Binding PurchaseDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Cost" Binding="{Binding Cost}" Width="80"/>
                <DataGridTextColumn Header="ResponsiblePerson" Binding="{Binding ResponsiblePerson}" Width="140"/>
                <DataGridTextColumn Header="UserCount" Binding="{Binding UserCount}" Width="80"/>
                <DataGridTextColumn Header="ExpirationDate" Binding="{Binding ExpirationDate, StringFormat=dd.MM.yyyy}" Width="100"/>
                <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Статус бар -->
        <StatusBar Grid.Row="4" Background="#2C3E50" Foreground="White" Height="30">
            <StatusBarItem>
                <TextBlock Name="txtStatus" Text="Готов к работе"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Данные сохраняются в software.txt"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>